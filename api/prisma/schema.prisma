  discount_codes discount_codes @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  users          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([appliedAt])
  @@index([discountCodeId])
  @@index([userId])
}

model gdpr_consents {
