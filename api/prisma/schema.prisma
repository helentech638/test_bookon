model user_notification_preferences {
  id                        String   @id
  userId                    String   @unique
  inAppEnabled              Boolean  @default(true)
  emailEnabled              Boolean  @default(true)
  smsEnabled                Boolean  @default(false)
  pushEnabled               Boolean  @default(true)
  bookingCreatedEnabled     Boolean  @default(true)
  bookingUpdatedEnabled     Boolean  @default(true)
  bookingCancelledEnabled   Boolean  @default(true)
  bookingTransferredEnabled Boolean  @default(true)
  paymentSuccessEnabled     Boolean  @default(true)
  paymentFailedEnabled      Boolean  @default(true)
  activityReminderEnabled   Boolean  @default(true)
  systemAlertEnabled        Boolean  @default(true)
  quietHoursEnabled         Boolean  @default(false)
